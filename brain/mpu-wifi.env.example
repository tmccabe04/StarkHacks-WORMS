# Copy to mpu-wifi.env in this folder (keep secrets out of git).
# Used by: make wifi-push
#
# SSH must reach the UNO Q Linux shell (USB Ethernet gadget, mDNS, or Wi‑Fi
# after first manual join). Prefer SSH keys so this is non-interactive.

export UNO_Q_SSH=arduino@arduino.local
# export UNO_Q_SSH_OPTS="-o StrictHostKeyChecking=accept-new"

export WIFI_SSID=your_network_name
export WIFI_PSK=your_wifi_password
