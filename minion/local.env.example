# Copy to local.env (created by ../scripts/setup.sh) and edit.
# Used by the minion Makefile to compile/upload and to generate src/secrets.h

export FQBN="${FQBN:-esp32:esp32:esp32c6}"

# Optional: set when auto-detection picks the wrong serial port
# export MINION_PORT=/dev/cu.usbmodemXXXX

# If upload fails with esptool "Checksum error" / "Failed to write to target RAM":
# - try a shorter data USB cable / different port; or
# - lower baud (Makefile default is already 115200), e.g. keep 115200; or
# - skip the RAM stub (slower but avoids stub checksum failures):
# export ESP32_NO_STUB=1
# export ESP32_UPLOAD_VERBOSE=1

# Minion → brain (UNO Q Linux Wi‑Fi / LAN address after it joins the network)
export BRAIN_IP="192.168.1.100"
# export BRAIN_PORT=8080

export WIFI_SSID="your_network_name"
export WIFI_PSK="your_wifi_password"
